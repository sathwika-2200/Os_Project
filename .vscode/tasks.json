{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build DFS",
            "type": "shell",
            "command": "gcc",
            "args": [
                "main.c",
                "node_manager.c",
                "replication.c",
                "fault_tolerance.c",
                "-o",
                "dfs.exe",
                "-Wall",
                "-Wextra",
                "-std=c11",
                "-O2"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Generated task by Antigravity to build the DFS project."
        },
        {
            "label": "Run Web Server (Python)",
            "type": "shell",
            "command": "python",
            "args": [
                "-m",
                "http.server",
                "8000"
            ],
            "problemMatcher": [],
            "detail": "Starts the local Python server for the dashboard."
        }
    ]
}
